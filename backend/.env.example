# CXR Report Generator — Environment Configuration
# Copy this file to .env and fill in your values

MODEL_PATH=model/densenet121_mimic_finetuned.pt
FAISS_INDEX_PATH=index/faiss.index
RETRIEVAL_METADATA_JSON=index/metadata.json
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_api_key_here
TOP_K=5
CNN_THRESHOLD=0.2
LABELS=["Atelectasis","Cardiomegaly","Effusion","Pneumonia","Pneumothorax","Edema","No Finding"]

# Confidence improvement parameters
# TEMPERATURE: Lower = sharper/more confident predictions (0.3-0.7 recommended)
TEMPERATURE=0.5
# TTA_ENABLED: Test-Time Augmentation (5 augmented views, averaged)
TTA_ENABLED=true
# CNN_WEIGHT / EVIDENCE_WEIGHT: Fusion weights for final confidence (must sum to 1.0)
CNN_WEIGHT=0.6
EVIDENCE_WEIGHT=0.4
# SECONDARY_THRESHOLD: Sigmoid threshold for reporting additional findings
SECONDARY_THRESHOLD=0.3
